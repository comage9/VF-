# ============================================
# VF Analytics Dashboard - 환경변수 설정
# ============================================
# 사용법: cp .env.sample .env
# 그 후 .env 파일에 실제 값을 입력하세요.

# ============================================
# 깃 (Git)
# ============================================
# 깃허브 토큰 (푸시용)
# 생성: GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic)
# 권한: repo (전체 체크)
gittoken=github_pat_YourTokenHere

# ============================================
# Google Sheets (데이터 동기화)
# ============================================
# VF 출고 데이터 Google Sheets CSV export URL
OUTBOUND_GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vQwqI0BG-d2aMrql7DK4fQTjvu57VtToSLAkY_nq92a4Cg5GFVbIn6_IR7Fq6_O-2TloFSNlXT8ZWC/pub?gid=1152588885&single=true&output=csv

# Google Sheets API 키 (새로고침 기능용)
GOOGLE_SHEETS_API_KEY=

# ============================================
# API 설정
# ============================================
# AI 모델 설정 (Claude/Sonnet 등)
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-4.6
ANTHROPIC_AUTH_TOKEN=YourAuthTokenHere
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
API_TIMEOUT_MS=3000000

# Ollama (로컬 LLM - 선택사항)
ollama_base_url=http://localhost:11434
ollama_model=llama3.1

# ============================================
# 서버 설정
# ============================================
# Django 백엔드 URL (프론트엔드 프록시용)
DJANGO_BASE_URL=http://localhost:5176

# 서버 호스트 (외부 접속 허용: 0.0.0.0)
# 로컬만: SERVER_HOST=localhost 또는 생략
SERVER_HOST=0.0.0.0

# 서버 포트 (기본값: 5174)
PORT=5174

# ============================================
# 참고
# ============================================
# 1. 백엔드 실행: cd backend && source .venv/bin/activate && python manage.py runserver 0.0.0.0:5176
# 2. 프론트엔드 실행: cd frontend && npm install && npm run dev
# 3. 접속 URL: http://localhost:5174/sales/outbound
