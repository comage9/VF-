# Frontend 환경변수 예시
# 사용법: cp .env.example .env.local

# ============================================
# API 설정
# ============================================
# Django 백엔드 URL (프록시 대상)
DJANGO_BASE_URL=http://localhost:5176

# ============================================
# 서버 설정
# ============================================
# 서버 호스트 (외부 접속 허용: 0.0.0.0, 로컬만: localhost)
SERVER_HOST=0.0.0.0

# 서버 포트
PORT=5174
