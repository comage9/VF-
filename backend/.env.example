# Backend 환경변수 예시
# 사용법: cp .env.example .env.local

# ============================================
# 구글 시트 (FC 입고 데이터)
# ============================================
# Google Sheets API Key (Required for 'google_sheets_refresh')
GOOGLE_SHEETS_API_KEY=your_api_key_here

# FC 입고 데이터 구글 시트 CSV URL (File -> Share -> Publish to web -> CSV)
FC_GOOGLE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/e/.../pub?output=csv

# ============================================
# 마스터 데이터 (카테고리 정보)
# ============================================
# 마스터 데이터 구글 시트 CSV URL
MASTER_DATA_CSV_URL=https://docs.google.com/spreadsheets/d/e/.../pub?output=csv

# ============================================
# 출고 데이터 (Outbound Data)
# ============================================
# 출고 데이터 구글 시트 CSV URL
OUTBOUND_GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/e/.../pub?output=csv
# ============================================
# AI 설정 (Anthropic 또는 Ollama)
# ============================================
# AI 백엔드 선택 (anthropic 또는 ollama)
AI_BACKEND=ollama

# Anthropic 설정 (AI_BACKEND=anthropic 인 경우 필수)
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_AUTH_TOKEN=your_token_here
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-4.7

# Ollama 설정 (AI_BACKEND=ollama 인 경우 필수)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=lfm2.5-thinking:latest

# 타임아웃 설정 (ms)
API_TIMEOUT_MS=60000
